{
  "name": "@digitalforgestudios/pavlov-react",
  "version": "0.1.0",
  "description": "Pavlov — React hooks and headless components for gamification.",
  "license": "MIT",
  "author": "Digital Forge Studios",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalforgestudios/pavlov.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@digitalforgestudios/pavlov-core": ">=0.1.0"
  },
  "devDependencies": {
    "@digitalforgestudios/pavlov-core": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": ["gamification", "react", "hooks", "xp", "levels", "badges", "streaks"]
}
