{
  "name": "@digitalforgestudios/pavlov-core",
  "version": "0.1.0",
  "description": "Pavlov — configurable gamification engine. Pure logic, zero dependencies.",
  "license": "MIT",
  "author": "Digital Forge Studios",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalforgestudios/pavlov.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["gamification", "xp", "levels", "badges", "streaks", "achievements", "engagement"]
}
